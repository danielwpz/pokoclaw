{
  "name": "pokeclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --error-on-warnings .",
    "format": "biome check --write --error-on-warnings .",
    "test": "vitest run --passWithNoTests",
    "test:integration:llm": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "preflight": "pnpm build && pnpm format && pnpm lint && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs,json}": [
      "biome check --write --no-errors-on-unmatched --error-on-warnings"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@danielwpz/sandbox-runtime": "0.0.43-pokeclaw.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@mariozechner/pi-agent-core": "0.58.0",
    "@mariozechner/pi-ai": "0.58.0",
    "@sinclair/typebox": "^0.34.48",
    "@tavily/core": "^0.7.2",
    "better-sqlite3": "^12.8.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "openai": "6.26.0",
    "toml": "^3.0.0"
  }
}
